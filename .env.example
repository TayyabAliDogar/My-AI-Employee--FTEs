# Odoo Configuration
ODOO_URL=http://localhost:8069
ODOO_DB=oddo_ai
ODOO_USER=admin
ODOO_PASSWORD=admin

# Instagram/Facebook Integration (same access token)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# Twitter/X Integration
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# Gmail Integration (from Silver tier)
GMAIL_CREDENTIALS_PATH=.kiro cli/skills/gmail-watcher/scripts/credentials.json

# LinkedIn Integration (from Silver tier)
LINKEDIN_EMAIL=your_linkedin_email_here
LINKEDIN_PASSWORD=your_linkedin_password_here

# Ngrok (optional - for public access)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# PostgreSQL (for Docker deployment)
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo
POSTGRES_DB=postgres
